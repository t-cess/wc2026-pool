rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===== สิทธิ์ 3 ระดับ =====
    // super = ต้น (ของกลาง: ตารางคู่ + แต่งตั้งแอดมิน/สร้างวง) — ถอดไม่ได้
    function isSuper() {
      return request.auth != null
        && request.auth.token.email in ['ton.itthiphon@gmail.com'];
    }
    // แอดมินวงหลัก (top-level) = super หรือ อีเมลใน config/admins
    function topAdmin() {
      return isSuper() ||
        ( request.auth != null
          && exists(/databases/$(database)/documents/config/admins)
          && request.auth.token.email in get(/databases/$(database)/documents/config/admins).data.emails );
    }
    // แอดมินวงอื่น = super หรือ อีเมลใน pools/{pool}/config/admins
    function poolAdmin(pool) {
      return isSuper() ||
        ( request.auth != null
          && exists(/databases/$(database)/documents/pools/$(pool)/config/admins)
          && request.auth.token.email in get(/databases/$(database)/documents/pools/$(pool)/config/admins).data.emails );
    }
    // โพยแก้ได้ถ้า = เจ้าของ (doc มี uid ตรง) · เขียนได้เฉพาะฟิลด์โพย (ห้ามแตะ scorerOk/s1hit/... รวมถึง revealed → กันแอบเปิดเผยโพยตัวเองก่อนเตะ) · ยังก่อนเตะเกิน 10 นาที
    function ownerBeforeKickoff() {
      return request.auth.uid == request.resource.data.uid
        && request.resource.data.keys().hasOnly(['uid','matchId','player','homeScore','awayScore','scorer1','scorer2','advancePick'])
        && request.time.toMillis()
           < get(/databases/$(database)/documents/matches/$(request.resource.data.matchId)).data.kickoff - 600000;
    }
    // marker "ใครส่งโพยแล้ว" (สาธารณะ · ไม่มีสกอร์) — id = "{matchId}__{uid}" · เจ้าของเขียนของตัวเอง (player ต้องตรงชื่อลงทะเบียน) หรือแอดมิน
    function ownsMarker(pid, nameDoc) {
      return request.auth.uid == request.resource.data.uid
        && request.resource.data.keys().hasOnly(['uid','matchId','player'])
        && pid == request.resource.data.matchId + '__' + request.auth.uid
        && request.resource.data.player == get(nameDoc).data.name;
    }
    // ทายแชมป์ (champ1/champ2 = +10/ทีม) ห้ามแก้เมื่อล็อกแล้ว — บังคับที่ rule (UI canPick กันได้แค่ฝั่งจอ · ยิง Firestore ตรงได้ +10)
    function champLocked(tDoc) {
      return exists(tDoc) && (get(tDoc).data.get('picksLocked', false) || get(tDoc).data.get('championLocked', false));
    }
    // champ ต้องไม่เปลี่ยนจากค่าเดิม (create: resource==null → ต้องว่าง · ให้แก้ name/photo ได้ตามปกติ)
    function champUnchanged() {
      return request.resource.data.get('champ1','') == (resource == null ? '' : resource.data.get('champ1',''))
        && request.resource.data.get('champ2','') == (resource == null ? '' : resource.data.get('champ2',''));
    }

    // ===== คู่แข่งขัน: ใช้ร่วมทุกวง — อ่านได้หมด · เพิ่ม/แก้/ลบ = super เท่านั้น =====
    match /matches/{id} { allow read: if request.auth != null; allow write: if isSuper(); }

    // ===== วงหลัก (top-level) =====
    // ผู้เล่น: ชื่อ/รูป/ทายแชมป์ = public ในแอปอยู่แล้ว → คน login อ่านได้ (คนใหม่ต้องอ่านรายชื่อตอน self-register)
    //   email ไม่อยู่ใน doc นี้แล้ว (แยกไป emails/{uid} gated) → เปิดอ่านได้ไม่รั่ว PII
    match /players/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && ( topAdmin()
        || ( request.auth.uid == uid
             && ( !champLocked(/databases/$(database)/documents/config/tournament) || champUnchanged() ) ) );
    }
    // อีเมล (PII) = เจ้าของ + แอดมินวงหลักเท่านั้น
    match /emails/{uid} {
      allow read, write: if request.auth != null && (request.auth.uid == uid || topAdmin());
    }
    // ตั้งค่า: admins/meta = super (แต่งตั้ง/สร้าง) · ที่เหลือ (carry/tournament/champPicks/...) = แอดมินวงหลัก
    match /config/{id} {
      allow read: if request.auth != null;
      allow write: if (id == 'admins' || id == 'meta') ? isSuper() : topAdmin();
    }
    // โพย: อ่านได้เฉพาะ เจ้าของ / โพยที่เปิดเผยแล้ว (revealed=true · auto-grade พลิกตอนคู่เริ่มเตะ) / แอดมิน — กันคนแอบดูสกอร์คนอื่นก่อนเตะ (UI ซ่อนไม่พอ ต้องกันที่ rule)
    //   revealed (ไม่ใช่ kickoff<now) เพราะ list query authorize จาก "ข้อจำกัด query" ที่ต้อง match แบบ equality — where("revealed","==",true) ใช้ได้ชัวร์
    match /predictions/{pid} {
      allow read: if request.auth != null && ( resource.data.uid == request.auth.uid
        || resource.data.revealed == true
        || topAdmin() );
      // doc id = "{matchId}__{uid}" (1 ใบ/คน/คู่) + player ต้องตรงชื่อที่ลงทะเบียนของ uid → กันปั๊มแต้ม/ยัดชื่อคนอื่นแม้สมัคร alt · แอดมินเขียนอิสระ
      allow create, update: if request.auth != null && ( topAdmin()
        || ( ownerBeforeKickoff()
             && pid == request.resource.data.matchId + '__' + request.auth.uid
             && request.resource.data.player == get(/databases/$(database)/documents/players/$(request.auth.uid)).data.name ) );
      allow delete: if false;
    }
    // marker "ใครส่งแล้ว" (สาธารณะ ไม่มีสกอร์) — คน login อ่านได้หมด · เขียน = เจ้าของ/แอดมิน
    match /submitted/{pid} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null && ( topAdmin()
        || ownsMarker(pid, /databases/$(database)/documents/players/$(request.auth.uid)) );
      allow delete: if false;
    }

    // ===== วงอื่น (pools/{pool}) — แอดมินวงนั้นๆ ดูแลของตัวเอง · matches ยังใช้ร่วม top-level =====
    match /pools/{pool}/players/{uid} {
      allow read: if request.auth != null;   // ชื่อ/รูป/แชมป์ public · email แยกไป emails/{uid}
      allow write: if request.auth != null && ( poolAdmin(pool)
        || ( request.auth.uid == uid
             && ( !champLocked(/databases/$(database)/documents/pools/$(pool)/config/tournament) || champUnchanged() ) ) );
    }
    match /pools/{pool}/emails/{uid} {
      allow read, write: if request.auth != null && (request.auth.uid == uid || poolAdmin(pool));
    }
    match /pools/{pool}/config/{id} {
      allow read: if request.auth != null;
      allow write: if (id == 'admins' || id == 'meta') ? isSuper() : poolAdmin(pool);
    }
    match /pools/{pool}/predictions/{pid} {
      allow read: if request.auth != null && ( resource.data.uid == request.auth.uid
        || resource.data.revealed == true
        || poolAdmin(pool) );
      allow create, update: if request.auth != null && ( poolAdmin(pool)
        || ( ownerBeforeKickoff()
             && pid == request.resource.data.matchId + '__' + request.auth.uid
             && request.resource.data.player == get(/databases/$(database)/documents/pools/$(pool)/players/$(request.auth.uid)).data.name ) );
      allow delete: if false;
    }
    match /pools/{pool}/submitted/{pid} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null && ( poolAdmin(pool)
        || ownsMarker(pid, /databases/$(database)/documents/pools/$(pool)/players/$(request.auth.uid)) );
      allow delete: if false;
    }
  }
}
